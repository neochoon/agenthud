{
  "name": "agenthud",
  "version": "0.18.5",
  "description": "TUI dashboard for AI coding agents (Claude Code, Codex, Kiro): live monitor for parallel sessions and sub-agents across agents, with structured activity export and LLM-generated daily/weekly digests",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "agenthud": "dist/index.js"
  },
  "files": [
    "dist",
    "scripts"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:save": "npx tsx scripts/save-test-results.ts",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neochoon/agenthud.git"
  },
  "keywords": [
    "claude",
    "claude-code",
    "claude-code-cli",
    "claude-code-tui",
    "anthropic",
    "codex",
    "codex-cli",
    "openai-codex",
    "kiro",
    "kiro-cli",
    "kiro-ide",
    "agent",
    "ai-agent",
    "coding-agent",
    "ai-coding-agent",
    "agent-monitor",
    "sub-agent",
    "multi-agent",
    "tui",
    "terminal",
    "terminal-ui",
    "monitor",
    "live-monitor",
    "observability",
    "session",
    "sessions",
    "session-monitor",
    "session-manager",
    "dashboard",
    "digest",
    "summary",
    "llm",
    "llm-summary",
    "cli",
    "developer-tools"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/neochoon/agenthud/issues"
  },
  "homepage": "https://github.com/neochoon/agenthud#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.7",
    "@vitest/coverage-v8": "^4.0.16",
    "ink-testing-library": "^4.0.0",
    "jsdom": "^27.4.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "ink": "^6.6.0",
    "react": "^19.2.3",
    "string-width": "^8.1.0",
    "yaml": "^2.8.2"
  }
}
